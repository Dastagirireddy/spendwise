{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SpendWise",
  "version": "1.1.0",
  "identifier": "com.expense-tracker.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SpendWise",
        "width": 1100,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Finance",
    "shortDescription": "Track your daily expenses and monthly budget",
    "longDescription": "A beautiful desktop expense tracker to monitor daily spending, manage budgets, and analyze category-wise expenses.",
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Dastagirireddy/spendwise/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ2N0I1MDBCREY4MTY3QzEKUldUQlo0SGZDMUI3Um9MUjg4dFlPMTNoZzEvSXZIRm5FOHZiQ0h4WjZ4Q3ZGei83ZFVzQ2t3d2EK"
    }
  }
}
